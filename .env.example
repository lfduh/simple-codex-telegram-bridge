# ── Required ──────────────────────────────────────────────────────────────────

# Your Telegram bot token (from @BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
# Find yours: message @userinfobot on Telegram
ALLOWED_USER_IDS=YOUR_TELEGRAM_USER_ID_HERE

# ── Codex ─────────────────────────────────────────────────────────────────────

# Optional default directory for the first thread when no active thread exists
WORK_DIR=

# Model to use (o4-mini is fast and cheap; o3 for harder tasks)
CODEX_MODEL=o4-mini

# Approval mode:
#   on-request = ask before every task (recommended)
#   auto       = run immediately without asking
APPROVAL_MODE=on-request

# ── Optional tuning ───────────────────────────────────────────────────────────

# How long to wait for approval before auto-cancelling (ms, default 5 min)
APPROVAL_TIMEOUT_MS=300000

# How often to flush streaming output to Telegram (ms, default 2s)
STREAM_DEBOUNCE_MS=2000

# Local JSON file storing Telegram chat/thread metadata
STATE_FILE=

# Recent threads kept per chat in the local state file
MAX_RECENT_THREADS=10
