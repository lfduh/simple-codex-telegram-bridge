# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to use the bot
# Find yours: Discord Settings → Advanced → Developer Mode → right-click your name
ALLOWED_USER_IDS=123456789012345678

# ── Codex ─────────────────────────────────────────────────────────────────────

# Absolute path to the codebase Codex will operate on
WORK_DIR=/path/to/your/project

# Model to use (o4-mini is fast and cheap; o3 for harder tasks)
CODEX_MODEL=o4-mini

# Approval mode:
#   on-request = ask before every task (recommended)
#   auto       = run immediately without asking (danger: no gate)
APPROVAL_MODE=on-request

# ── Optional tuning ───────────────────────────────────────────────────────────

# How long to wait for approval before auto-cancelling (ms, default 5 min)
APPROVAL_TIMEOUT_MS=300000

# How often to flush streaming output to Discord (ms, default 1.5s)
# Lower = more real-time but risks Discord rate limits
STREAM_DEBOUNCE_MS=1500
